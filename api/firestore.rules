rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()  { return request.auth != null; }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Usuários: admin lê/escreve tudo; operador lê só o próprio
    match /users/{uid} {
      allow read:   if isAuth() && (isAdmin() || request.auth.uid == uid);
      allow write:  if isAdmin();
      allow create: if isAuth() && request.auth.uid == uid; // auto-registro no primeiro login
    }

    // Códigos dos funcionários: todos autenticados lêem; admin escreve
    match /employees/{cpf} {
      allow read:  if isAuth();
      allow write: if isAuth(); // qualquer operador pode atualizar código
    }

    // Logs: autenticados criam; admin lê tudo; operador lê só os seus
    match /processLogs/{logId} {
      allow create: if isAuth();
      allow read:   if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
    }

    // Convites: só admin
    match /invites/{token} {
      allow read, write: if isAdmin();
      allow read: if true; // qualquer um pode ler para validar o token
    }
  }
}
